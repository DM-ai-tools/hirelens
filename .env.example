# Database — Railway: use ${{Postgres.DATABASE_URL}} or your Postgres connection string
DATABASE_URL="postgresql://postgres:root@localhost:5432/hirelens?schema=public"
# Optional: superuser URL used only by db:setup to create the hirelens database
DATABASE_ADMIN_URL="postgresql://postgres:root@localhost:5432/postgres"

# NextAuth — Railway: set to your public app URL (e.g. https://your-app.up.railway.app)
NEXTAUTH_URL="http://localhost:3001"
AUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="change-this-to-a-secure-random-string-in-production"
AUTH_SECRET="change-this-to-a-secure-random-string-in-production"

# AI
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5"
USE_MOCK_AI="true"

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="HireLens <onboarding@resend.dev>"

# Redis (optional — inline queue used when USE_REDIS_QUEUE is not true)
REDIS_URL="redis://localhost:6379"
USE_REDIS_QUEUE="false"

# Storage — use absolute paths in Docker/Railway
UPLOAD_DIR="/app/uploads"
REPORT_DIR="/app/reports"

# Server — Railway injects PORT automatically (often 8080). Do not hardcode PORT=3000 on Railway.
PORT=8080
HOSTNAME="0.0.0.0"
NODE_ENV="production"

# Seed / demo login accounts (created by `npm run db:seed` — run once on Railway after deploy)
DEMO_ADMIN_EMAIL="admin@dotmappers.in"
DEMO_ADMIN_PASSWORD="admin123"
DEMO_RECRUITER_EMAIL="recruiter@dotmappers.in"
DEMO_RECRUITER_PASSWORD="recruiter123"
# Admin login: /login/admin  →  dashboard: /admin
SHOW_DEMO_CREDENTIALS="false"
